const { DataTypes } = require('sequelize');
const sequelize = require('../config/database');

const FluidType = sequelize.define('FluidType', {
  id: {
    type: DataTypes.CHAR(36),
    defaultValue: DataTypes.UUIDV4,
    primaryKey: true
  },
  name: { type: DataTypes.STRING(100), allowNull: false },
  density: { type: DataTypes.DECIMAL(6, 3), allowNull: true },
  safe_max_drop_rate: { type: DataTypes.INTEGER, allowNull: true }
}, {
  tableName: 'fluid_types',
  timestamps: true,
  createdAt: 'created_at',
  updatedAt: false
});

module.exports = FluidType;